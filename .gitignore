# Ignorar archivos temporales generales de sistema
*.tmp
*.temp
*.bak
*.swp
*.log

# Archivos de caché de editores
*.DS_Store
Thumbs.db

# Archivos comprimidos y paquetes
*.zip
*.tar
*.gz
*.rar
*.7z

# Archivos de configuración de IDEs (si no son de Unity)
*.idea/
*.vscode/
*.iml
*.sublime-workspace
*.sublime-project

# Archivos generados por compilación fuera de Unity
/bin/
/obj/

# Ignorar archivos grandes específicos si quieres
*.mp4
*.mov
*.avi
*.exe